{
    "name": "opticore-template-mysqldb",
    "version": "1.0.0",
    "description": "Opticore API Restfull template with mysql as database",
    "scripts": {
        "start:prod": "tsx server.ts",
        "start:dev": "tsx server.ts",
        "stop": "sh -c 'lsof -i :${PORT:-4200} -t'",
        "db:migrate": "npx prisma migrate dev --name user-entity --create-only && npx prisma generate",
        "db:push": "npx prisma db push",
        "test": "jest --forceExit --detectOpenHandles",
        "deploy:prod": "npm run build && pm2 start ecosystem.config.js --only prod",
        "deploy:dev": "pm2 start ecosystem.config.js --only dev",
        "lint": "ESLINT_USE_FLAT_CONFIG=true eslint --ext .ts src/",
        "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint --fix --ext .ts src/"
    },
    "repository": {
        "type": "git",
        "url": "git+ https://github.com/guyzoum77/opticore-api-restfull-template-mysql.git"
    },
    "author": "Guy-serge Kouacou",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/guyzoum77/opticore-api-restfull-template-mysql.git/issues"
    },
    "homepage": "https://github.com/guyzoum77/opticore-api-restfull-template-mysql.git#readme",
    "dependencies": {
        "@types/gradient-string": "^1.1.6",
        "opticore-catch-exception-error": "^1.0.27",
        "opticore-env-access": "^1.0.14",
        "opticore-express": "^1.0.7",
        "opticore-feature-module": "^1.0.30",
        "opticore-http-response": "^1.0.9",
        "opticore-loader-translation": "^1.0.3",
        "opticore-logger": "^1.0.23",
        "opticore-mysqldb": "^1.0.40",
        "opticore-request-call-event": "^1.0.8",
        "opticore-router": "^1.0.19",
        "opticore-server-logger": "^1.0.8",
        "opticore-translator": "^1.0.11",
        "opticore-validator": "^1.0.3",
        "opticore-webapp": "^1.0.69",
        "opticore-webapp-core": "^1.0.20",
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^0.1.0",
        "@eslint/js": "^9.39.2",
        "@types/node": "^25.0.9",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "globals": "^17.0.0",
        "supertest": "^7.2.2",
        "tsx": "^4.19.4",
        "typescript": "^5.4.5"
    }
}
