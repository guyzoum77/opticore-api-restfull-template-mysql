# ============================================
#                   SERVER
# ============================================
APP_HOST=localhost
APP_PORT=4200


# ============================================
#                   WEB APP SERVER
# ============================================
ROOT_DIR=src
WATCH_EXTENSIONS=
HOT_RELOAD_EXTENSIONS=
IGNORE=
DEBOUNCE_MS=

# ============================================
#                 DEPLOYEMENT
# ============================================
ENV_DEV=dev
ENV_PROD=


# ============================================
#                  DATABASE
# ============================================
DATA_BASE_USER=
DATA_BASE_PASSWORD=
DATA_BASE_NAME=
DATA_BASE_HOST=localhost
DATA_BASE_PORT=3306

#ARG CONNEXION
ARGUMENTS_DATABASE_CONNECTION=

#API VERSION
API_VERSION=

# ============================================
#                PASSPORT FIELD
# ============================================
USERNAME_FIELD=
PASSWORD_FIELD=

#LOCAL LANGUAGE
DEFAULT_LOCAL_LANG=en
#Example : #France (fr-FR), USA (en-US), Japan (ja-JP)
LOCAL_FORMAT_TIME=en-US

#PROTOCOL TRANSFER
PROTOCOL_TRANSFER=http

# ============================================
#             WATCHER FILE
# ============================================
HMR_ENABLED=true
HMR_WATCH_PATTERNS="src/**/*.ts,src/**/*.js,src/**/*.json,.env,config/*.json"
HMR_IGNORE_PATTERNS="node_modules/**,dist/**,build/**,*.log,coverage/**"
HMR_DEBOUNCE_MS=500
HMR_MAX_RESTARTS=5
HMR_AUTO_RESTART=false


# ============================================
#           WEB DEBUG TOOLBAR
# ============================================
# Set to true to display the debug toolbar on the home page
PROFILE_WEB_TOOL_BAR=true


# ============================================
#             LOGGER FILE CONFIG
# ============================================
LOG_ENVIRONMENT=
LOG_ENVIRONMENT_FILE_MAX_SIZE=
LOG_ENVIRONMENT_FILE_ROTATE=
LOG_ENVIRONMENT_FILE_ENABLED=
LOG_ENVIRONMENT_REMOTE_ENDPOINT=
LOG_ENVIRONMENT_REMOTE_ENABLED=
LOG_ENVIRONMENT_CONSOLE_ENABLED=
LOG_ENVIRONMENT_LOG_LEVEL_ERROR=
LOG_ENVIRONMENT_LOG_LEVEL_INFO=
LOG_ENVIRONMENT_LOG_LEVEL_SUCCESS=
LOG_ENVIRONMENT_LOG_LEVEL_WARN=
LOG_ENVIRONMENT_LOG_LEVEL_DEBUG=